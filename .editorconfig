root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
line_length = 80
indent_size = 2
indent_style = tab

[*.{js,mjs}]
indent_style = tab
indent_size = 2

[*.{yaml,yml}]
indent_style = space

[*.{html,njk}]
indent_style = tab
indent_size = 2

[*.{md,txt}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = false
