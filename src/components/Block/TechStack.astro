---
import { __ } from '@i18n/utils';
import type { Content } from '@prismicio/client';
import { getAllTechStackSections } from '@src/prismic';
import Tabs from '@components/Block/Tabs.astro';
import LogoIcon from '@components/Block/LogoIcon.astro';

const sections = await getAllTechStackSections().then((response) => response.results);

const tabs = sections.map((section) => ({
	title: section.data.heading || section.uid,
	id: `tabpanel_${section.uid}`,
}));
---

<x-tech-stack class="stack col">
	<h2>{__('component.techstack.title')}</h2>

	{
		sections.length > 0 && (
			<Tabs
				className="xt-stack"
				tabs={tabs}
				orientation={'horizontal'}
				title={__('component.techstack.title')}
			>
				{sections.map((section, sectionIndex) => (
					<x-tabpanel
						class="xt-stack-panel"
						role="tabpanel"
						tabindex={sectionIndex}
						id={`tabpanel_${section.uid}`}
						data-category={section.uid}
						data-tab-panel={`tabpanel_${section.uid}`}
						x-show="isActiveTab"
					>
						<ol class="stack-items">
							{section.data.items.map((item: Content.TechStackSectionDocumentDataItemsItem) => (
								<li class="stack-item">
									<span class="stack-item-logo">
										<LogoIcon
											size={32}
											icon={String(item.icon ?? item.title ?? '')
												.replace(/\s+/g, '-')
												.toLowerCase()}
										/>
									</span>
									<span class="stack-item-title">{item.title}</span>
								</li>
							))}
						</ol>
					</x-tabpanel>
				))}
			</Tabs>
		)
	}
</x-tech-stack>

<style>
	h2 {
		text-align: center;
		margin: 0 0 var(--gap-lg) 0;
	}

	.stack-items {
		display: grid;
		gap: var(--gap-xs);
		grid-template-columns: 1fr 1fr;
		list-style-type: none;
		margin: 0;
		padding: 0;
	}

	.stack-item {
		display: flex;
		flex-direction: row;
		gap: var(--gap-xxs);
		align-items: center;
		border-radius: calc(var(--border-radius) * 2);
		padding: var(--gap-xxs);
		background: var(--surface-2);
		margin: 0;
	}

	.stack-item-title {
		text-align: center;
		font-size: x-small;
		padding: var(--gap-xxs);
	}

	.stack-item-logo {
		display: inline-flex;
		align-content: center;
		padding: var(--gap-xs);
	}

	@media (--vp-sm) {
		.stack-items {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (--vp-lg) {
		.stack-items {
			grid-template-columns: repeat(auto-fill, minmax(250px, auto));
		}
	}
</style>

<style is:global>
	.xt-stack-wrapper {
		margin: var(--gap-sm) 0;
	}

	.xt-stack-panels {
		flex: 1 1 auto;
		overflow: hidden;
		border-radius: calc(var(--border-radius) * 3);
		background-color: var(--surface-2);
	}

	.xt-stack-tab {
		display: flex;
		font-size: small;
	}

	.xt-stack-tablist {
		display: flex;
		flex-direction: row;
		flex-wrap: nowrap;
		gap: var(--gap-xs);
		padding: var(--gap);
		max-width: 100%;
		overflow: scroll;
		scrollbar-width: none;
	}

	.xt-stack-label {
		position: relative;
		display: flex;
		flex: 1 1 auto;
		cursor: pointer;
		color: var(--text-muted);
		font-weight: 400;
		background-image: none;
		background-color: var(--surface-1);
		border: var(--border-width) solid var(--surface-2);
		padding: var(--gap-xs) var(--gap);
		white-space: nowrap;
		border-radius: calc(var(--border-radius));
	}

	.xt-stack-tablist.col .xt-stack-label {
		border-radius: var(--border-radius) 0 0 var(--border-radius);
	}

	input[type='radio']:checked + .xt-stack-label {
		color: var(--text);
		background-color: var(--surface-3);
		border: var(--border-width) solid var(--surface-3);
	}

	.xt-stack-tablist.col input[type='radio']:checked + .xt-stack-label {
		background-position: 100% 0;
	}

	.xt-stack-label:hover {
		color: var(--text);
	}

	.xt-stack-panel {
		display: flex;
		flex-direction: column;
		border: 0;
		padding: var(--gap);
		background-color: var(--surface-1);

		p {
			font-size: small;
			margin-bottom: var(--gap);
		}
	}

	@media (--vp-md) {
		.xt-stack-tab {
			font-size: medium;
		}

		.xt-stack-label {
			padding: var(--gap-sm) var(--gap-xl);
			border-radius: calc(var(--border-radius) * 3);
		}
	}

	@media (--vp-lg) {
		.xt-stack-tablist {
			flex-direction: row;
			gap: var(--gap-sm);
			margin: 0 0 var(--gap) 0;
		}
	}
</style>
