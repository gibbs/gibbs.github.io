---
import { __ } from '@i18n/utils';
import '@styles/vendor/github-language-colours.css';
---

<x-in x-data="xin" x-intersect:once="boot" x-on:x-insights.document="update($event)">
	<div class="xin" x-show="show == true" x-cloak>
		<section class="xin-panel">
			<h3>{__('component.insights.heading.popularity')}</h3>

			<template x-if="loading">
				<p class="xin-muted">{__('component.insights.loading')}</p>
			</template>

			<template x-if="!loading && popularity.length === 0">
				<p class="xin-muted">{__('component.insights.nodata')}</p>
			</template>

			<ul class="xin-bar-chart" x-show="popularity.length > 0">
				<template x-for="language in popularity" :key="language.name">
					<li class="xin-bar-item">
						<span class="xin-bar-progress">
							<span
								:class="'xin-bar-progress-value gh-language gh-language--' + languageClass(language.name)"
								:style="{ width: language.width + '%' }"></span>
							<span
								class="xin-bar-title"
								x-text="language.name + ' (' + language.percentage.toFixed(1) + '%)'"></span>
						</span>
					</li>
				</template>
			</ul>
		</section>

		<section class="xin-panel">
			<h3>{__('component.insights.heading.distribution')}</h3>

			<div class="xin-distribution" x-show="distribution.length > 0">
				<div
					class="xin-pie"
					role="img"
					aria-label="Language distribution chart"
					:style="{ background: pieGradient }"
				>
				</div>

				<ol class="xin-language-key">
					<template x-for="language in distribution" :key="'key-' + language.name">
						<li
							:class="'gh-language gh-language--' + languageClass(language.name) + (isLanguageActive(language.name) ? ' xin-language-key-active' : '')"
							x-on:mouseenter="setHoveredLanguage(language.name)"
							x-on:mouseleave="clearHoveredLanguage()"
							x-on:click="toggleSelectedLanguage(language.name)"
						>
							<span x-text="language.name"></span>
							<span class="xin-key-value" x-text="language.percentage.toFixed(1) + '%'"></span>
						</li>
					</template>
				</ol>
			</div>
		</section>

		<p class="text-center xin-footer"><small>{__('component.insights.source')}</small></p>
	</div>
</x-in>

<script>
	// @ts-nocheck
	document.addEventListener('alpine:init', () => {
		Alpine.data('xin', () => {
			return {
				show: false,
				loading: true,
				popularity: [],
				distribution: [],
				hoveredLanguage: '',
				selectedLanguage: '',
				limit: 10,

				palette: [
					'oklch(65% 0.17 250)',
					'oklch(62% 0.18 30)',
					'oklch(68% 0.15 145)',
					'oklch(70% 0.16 90)',
					'oklch(60% 0.13 315)',
					'oklch(72% 0.15 205)',
				],
				languageColorCache: {},

				boot() {
					this.show = true;
				},

				get pieGradient() {
					if (this.distribution.length === 0) {
						return 'conic-gradient(var(--surface-3) 0deg 360deg)';
					}

					let cursor = 0;
					const segments = this.distribution.map((item, index) => {
						const span = (item.percentage / 100) * 360;
						const end = Math.min(cursor + span, 360);
						const color = this.getPieSliceColor(item.name, index);
						const segment = `${color} ${cursor}deg ${end}deg`;
						cursor = end;
						return segment;
					});

					if (cursor < 360) {
						segments.push(`var(--surface-3) ${cursor}deg 360deg`);
					}

					return `conic-gradient(${segments.join(', ')})`;
				},

				update(event) {
					this.loading = false;

					if (!(event?.detail && typeof event.detail === 'object')) {
						this.reset();
						return;
					}

					const normalized = this.normalize(event.detail);

					if (normalized.popularity.length === 0 && normalized.distribution.length === 0) {
						this.reset();
						return;
					}

					this.popularity = normalized.popularity;
					this.distribution = normalized.distribution;
					this.clearHoveredLanguage();
					if (this.selectedLanguage) {
						const hasSelected = this.distribution.some(
							(item) => item.name === this.selectedLanguage,
						);
						if (!hasSelected) {
							this.selectedLanguage = '';
						}
					}
				},

				reset() {
					this.popularity = [];
					this.distribution = [];
					this.clearHoveredLanguage();
					this.selectedLanguage = '';
				},

				normalize(detail) {
					const usageSource = this.getUsageSource(detail);
					const normalizedUsage = usageSource
						.map((item) => this.normalizeUsageItem(item))
						.filter((item) => item.name.length > 0)
						.filter((item) => item.bytes > 0 || item.count > 0);

					if (normalizedUsage.length === 0) {
						return {
							popularity: [],
							distribution: [],
						};
					}

					const topByCount = [...normalizedUsage]
						.sort((a, b) => b.count - a.count)
						.slice(0, this.limit);

					const topByBytes = [...normalizedUsage]
						.sort((a, b) => b.bytes - a.bytes)
						.slice(0, this.limit);

					const totalCount = topByCount.reduce((sum, item) => sum + item.count, 0);
					const maxCount = Math.max(...topByCount.map((item) => item.count), 1);
					const totalBytes = topByBytes.reduce((sum, item) => sum + item.bytes, 0);

					const popularity = topByCount.map((item) => {
						const width = (item.count / maxCount) * 100;
						let percentage = 0;

						if (totalCount > 0) {
							percentage = (item.count / totalCount) * 100;
						}

						return {
							...item,
							percentage,
							width: Math.min(Math.max(width, 6), 100),
						};
					});

					const distribution = topByBytes.map((item) => {
						let percentage = 0;

						if (totalBytes > 0) {
							percentage = (item.bytes / totalBytes) * 100;
						}

						return {
							...item,
							percentage,
						};
					});

					return {
						popularity,
						distribution,
					};
				},

				getUsageSource(detail) {
					if (Array.isArray(detail.usage)) {
						return detail.usage;
					}

					if (detail.usage && typeof detail.usage === 'object') {
						return Object.values(detail.usage);
					}

					if (Array.isArray(detail?.stats?.usage)) {
						return detail.stats.usage;
					}

					return [];
				},

				normalizeUsageItem(item) {
					const name = String(item?.name ?? '').trim();
					const bytes = Number(item?.bytes ?? 0);
					const count = Number(item?.count ?? 0);

					let normalizedBytes = 0;
					let normalizedCount = 0;

					if (Number.isFinite(bytes) && bytes > 0) {
						normalizedBytes = bytes;
					}

					if (Number.isFinite(count) && count > 0) {
						normalizedCount = count;
					}

					return {
						name,
						bytes: normalizedBytes,
						count: normalizedCount,
					};
				},

				setHoveredLanguage(name) {
					this.hoveredLanguage = name;
				},

				clearHoveredLanguage() {
					this.hoveredLanguage = '';
				},

				toggleSelectedLanguage(name) {
					if (this.selectedLanguage === name) {
						this.selectedLanguage = '';
						return;
					}

					this.selectedLanguage = name;
				},

				get activeLanguage() {
					if (this.hoveredLanguage) {
						return this.hoveredLanguage;
					}

					return this.selectedLanguage;
				},

				isLanguageActive(name) {
					if (!this.activeLanguage) {
						return false;
					}

					return name === this.activeLanguage;
				},

				getLanguageColor(name, index) {
					const key = this.languageClass(name);

					if (this.languageColorCache[key]) {
						return this.languageColorCache[key];
					}

					const fallback = this.palette[index % this.palette.length];

					if (typeof document === 'undefined') {
						return fallback;
					}

					const node = document.createElement('span');
					node.className = `gh-language gh-language--${key}`;
					node.style.position = 'absolute';
					node.style.opacity = '0';
					node.style.pointerEvents = 'none';
					node.style.inset = '0';
					document.body.appendChild(node);

					const color = window.getComputedStyle(node, '::before').backgroundColor;
					node.remove();

					const resolved = color && color !== 'rgba(0, 0, 0, 0)' ? color : fallback;
					this.languageColorCache[key] = resolved;
					return resolved;
				},

				getPieSliceColor(name, index) {
					const baseColor = this.getLanguageColor(name, index);

					if (!this.activeLanguage) {
						return baseColor;
					}

					if (name === this.activeLanguage) {
						return baseColor;
					}

					return `color-mix(in oklch, ${baseColor} 50%, var(--surface-2))`;
				},

				languageClass(name) {
					const value = String(name ?? '')
						.trim()
						.toLowerCase();

					return value
						.replace(/\+\+/g, 'pp')
						.replace(/#/g, 'sharp')
						.replace(/&/g, 'and')
						.replace(/\./g, '')
						.replace(/\s+/g, '-')
						.replace(/[^a-z0-9-]/g, '');
				},
			};
		});
	});
</script>

<style>
	h3 {
		text-align: center;
		margin-bottom: var(--gap);
	}

	.xin {
		display: grid;
		width: 100%;
		grid-template-columns: 1fr;
		gap: var(--gap-lg);
	}

	.xin-panel {
		display: flex;
		flex-direction: column;
		padding: var(--gap);
		border: var(--border-width) solid var(--border-color);
		border-radius: var(--border-radius);
		background: light-dark(var(--surface-i-2), var(--surface-1));
		min-height: 22rem;
	}

	.xin-panel h3 {
		margin-top: 0;
	}

	.xin-muted {
		margin: var(--gap) 0 0 0;
		color: var(--text-muted);
	}

	.xin-bar-progress {
		display: flex;
		height: 1.75rem;
		line-height: 1.75rem;
		border-radius: var(--border-radius-sm);
		overflow: hidden;
		background: var(--surface-2);
	}

	.xin-bar-progress-value {
		display: flex;
		height: 1.75rem;
		animation: xin-progress-bar 2s ease;
		transform-origin: left;
	}

	.xin-bar-chart {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		gap: var(--gap-xxs);
		list-style-type: none;
	}

	.xin-bar-item {
		position: relative;
		display: flex;
		justify-content: flex-end;
	}

	.xin-bar-progress {
		width: 100%;
	}

	.xin-bar-title {
		position: absolute;
		font-size: small;
		height: 1.75rem;
		line-height: 1.75rem;
		right: 0;
		top: 0;
		margin: 0 var(--gap-xs);
		color: var(--text);
		font-weight: 500;
	}

	.xin-bar-progress-value.gh-language::before {
		width: 100%;
		height: 1.5rem;
		margin: 0;
		border-radius: 0;
	}

	.xin-distribution {
		display: grid;
		gap: var(--gap-lg);
		align-items: start;
	}

	.xin-pie {
		width: min(26rem, 100%);
		aspect-ratio: 1;
		border-radius: 999px;
		margin: 0 auto;
		position: relative;
		box-shadow: 0 4px 20px color-mix(in oklch, var(--border-color) 40%, transparent);
		transition: background 320ms ease;
	}

	.xin-pie::after {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: 999px;
		box-shadow: inset 0 0 0 2px var(--border-color);
		pointer-events: none;
	}

	.xin-language-key {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		gap: var(--gap-xs);
		list-style: none;
		font-size: smaller;
	}

	.xin-language-key li {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: calc(var(--gap-xxs) / 2) var(--gap-xs);
		border-radius: var(--border-radius-sm);
		background: var(--surface-2);
		cursor: pointer;
		transition:
			background 180ms ease,
			box-shadow 180ms ease;
	}

	.xin-language-key li:hover,
	.xin-language-key li.xin-language-key-active {
		background: light-dark(var(--surface-i-3), var(--surface-3));
		box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--border-color), transparent 15%);
	}

	.xin-key-value {
		font-size: small;
		color: var(--text-muted);
		font-variant-numeric: tabular-nums;
	}

	.xin-footer {
		margin: 0;
	}

	.gh-language {
		font-size: small;
	}

	@media (--vp-md) {
		.xin {
			grid-template-columns: 1fr 1fr;
		}

		.xin-distribution {
			grid-template-columns: minmax(14rem, 18rem) 1fr;
			align-items: start;
		}

		.xin-footer {
			grid-column: 1 / -1;
		}

		.xin-language-key {
			display: grid;
			gap: var(--gap-sm);
			column-gap: var(--gap-sm);
		}

		.xin-language-key li {
			margin-bottom: 0;
		}
	}

	@media (--vp-lg) {
		.xin-distribution {
			grid-template-columns: minmax(18rem, 22rem) 1fr;
		}
	}

	@keyframes xin-progress-bar {
		0% {
			transform: scaleX(0);
		}
		100% {
			transform: scaleX(1);
		}
	}
</style>
