---
const {
	interval = false,
	format = 'TIME_24_WITH_SHORT_OFFSET',
	timezone = 'Europe/London',
} = Astro.props;
---

<time
	class="time"
	x-data="xtime"
	x-init="init"
	x-bind:datetime="getDatetime"
	x-text="getTime"
	data-interval={interval}
	data-format={format}
	data-timezone={timezone}>00:00:00 GMT</time
>

<script>
	const formats = {
		TIME_24_WITH_SHORT_OFFSET: {
			hour: 'numeric',
			minute: '2-digit',
			second: '2-digit',
			hourCycle: 'h23',
			timeZoneName: 'shortOffset',
		},
	};

	document.addEventListener('alpine:init', () => {
		Alpine.data('xtime', () => {
			return {
				date: new Date(),
				interval: 0,
				format: 'TIME_24_WITH_SHORT_OFFSET',
				timezone: 'Europe/London',

				init() {
					this.interval = parseInt(this.$el.dataset.interval) || this.interval;
					this.format = this.$el.dataset.format || this.format;
					this.timezone = this.$el.dataset.timezone || this.timezone;

					if (!this.interval) {
						this.date = new Date();
						return;
					}

					setInterval(() => {
						this.date = new Date();
					}, this.interval);
				},

				getTime() {
					return new Intl.DateTimeFormat(undefined, {
						...(formats[this.format] ?? formats.TIME_24_WITH_SHORT_OFFSET),
						timeZone: this.timezone,
					}).format(this.date);
				},

				getDatetime() {
					return this.date.toISOString();
				},
			};
		});
	});
</script>
