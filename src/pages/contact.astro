---
import BaseLayout from '@layouts/Base.astro';
import { env } from '@src/env.config';
import SliceLibrary from '@components/Prismic/SliceLibrary.astro';
import { getPageByUID } from '@src/prismic';
import { generateFrontmatter } from '@utils/frontmatter';
import GithubLink from '@components/Block/GithubLink.astro';
import LinkedInLink from '@components/Block/LinkedInLink.astro';
import Time from '@components/Block/Time.astro';
import '@styles/forms.css';
import '@styles/icons.css';
import '@styles/tool.css';

const page = await getPageByUID('contact', 'page');
const frontmatter = generateFrontmatter(page);
---

<BaseLayout frontmatter={frontmatter} url={Astro.url}>
	<SliceLibrary slices={page.data.slices} />

	<section class="contact">
		<ul class="links">
			<li>
				<span class="gg-time"></span>
				<Time interval={1000} format={'TIME_24_WITH_SHORT_OFFSET'} timezone={'Europe/London'} />
			</li>
			<li>
				<span class="gg-pin"></span>
				Devon, England, United Kingdom
			</li>
			<li>
				<GithubLink />
				<a href="https://github.com/gibbs">github.com/gibbs</a>
			</li>
			<li>
				<LinkedInLink />
				<a href="https://www.linkedin.com/in/dangibbscouk/">linkedin.com/in/dangibbscouk</a>
			</li>
		</ul>

		<form id="contact_form" class="form" method="post" x-data="contact_form" @submit.prevent="send">
			<fieldset class="fieldset fieldset-contact" x-show="!result.success">
				<legend class="hidden">Contact Form</legend>

				<div class="col">
					<label for="name">Name</label>
					<input
						type="text"
						autocomplete="name"
						id="name"
						name="name"
						placeholder="Your Name"
						minlength="1"
						maxlength="255"
						required
						x-bind:disabled="loading"
					/>
				</div>

				<div class="col" x-show="subject == true" x-cloak>
					<label for="subject">Subject</label>
					<input
						type="text"
						id="subject"
						name="subject"
						placeholder="Subject"
						minlength="1"
						maxlength="255"
						autocomplete="off"
						x-bind:disabled="loading"
					/>
				</div>

				<div class="col">
					<label for="email">Email</label>
					<input
						type="email"
						autocomplete="email"
						id="email"
						name="email"
						placeholder="email@address.com"
						minlength="1"
						maxlength="255"
						required
						x-bind:disabled="loading"
					/>
				</div>

				<div class="col">
					<label for="message">Message</label>
					<textarea
						name="message"
						rows="4"
						id="message"
						autocomplete="off"
						minlength="10"
						required
						x-bind:disabled="loading"></textarea>
				</div>
			</fieldset>

			<button
				type="submit"
				id="send"
				class="button"
				x-bind:disabled="loading"
				x-show="!result.success"
				>Send
			</button>

			<output
				class="result result-contact"
				x-cloak
				:class="result.class"
				x-show="result.output"
				x-text="result.output"></output>
		</form>
	</section>
</BaseLayout>

<script is:inline define:vars={{ APP_CONTACT_FORM_URL: env.APP_CONTACT_FORM_URL }}>
	document.addEventListener('alpine:init', () => {
		const url = new URL(APP_CONTACT_FORM_URL).toString();

		Alpine.data('contact_form', () => {
			return {
				loading: false,
				subject: false,
				success: true,
				result: {
					message: null,
					success: false,
				},

				send() {
					this.loading = true;
					const formData = new FormData(document.getElementById('contact_form'));

					fetch(url, {
						method: 'post',
						cache: 'no-cache',
						headers: {
							'content-type': 'application/json',
						},
						body: JSON.stringify(Object.fromEntries(formData)),
					})
						.then((res) => {
							if (!res.ok) {
								return res.json().then((errData) => {
									throw new Error(errData.error || 'Failed to send message');
								});
							}

							return res.json();
						})
						.then(() => {
							this.result = {
								class: 'result result-success',
								output: 'Thank you. Your message has been sent.',
								success: true,
							};
						})
						.catch((err) => {
							this.result = {
								class: 'result result-error',
								output: `Failed to send message. Please try again later. ${err}`,
								success: false,
							};
						})
						.finally(() => {
							this.loading = false;
						});
				},
			};
		});
	});
</script>

<style>
	.contact {
		display: grid;
		flex-direction: column;
		gap: var(--gap);
	}

	.links {
		display: flex;
		flex-direction: column;
		gap: var(--gap);
		margin: 0;
		padding: 0;
		list-style-type: none;

		li {
			display: flex;
			flex-direction: row;
			gap: var(--gap-xs);
			align-items: center;
		}

		[class^='gg-'] {
			transform: scale(1.25);
			margin-right: 4px;
		}

		.gg-pin {
			transform: rotate(45deg) scale(1.25);
		}
	}

	.fieldset-contact {
		display: flex;
		flex-direction: column;
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;
		gap: var(--gap);
	}

	.result-contact {
		display: block;
		width: 100%;
		margin: var(--gap) 0;
	}

	@media (--vp-lg) {
		.contact {
			grid-template-columns: auto 350px;
		}

		input {
			max-width: 60%;
		}

		.form {
			order: 1;
		}

		.links {
			margin: var(--gap) 0;
			padding: var(--gap-lg);
			order: 2;
		}
	}
</style>
