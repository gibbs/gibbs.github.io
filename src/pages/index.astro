---
import { __ } from '@i18n/utils';
import { getPageByUID } from '@src/prismic';
import { generateFrontmatter } from '@utils/frontmatter';
import BaseLayout from '@layouts/Base.astro';
import { env } from '@src/env.config';
import SliceLibrary from '@components/Prismic/SliceLibrary.astro';
import TechStack from '@components/Block/TechStack.astro';
import GithubActivityFeed from '@components/Block/GithubActivityFeed.astro';
import GithubInsights from '@components/Block/GithubInsights.astro';
import Time from '@components/Block/Time.astro';
import '@styles/icons.css';

const page = await getPageByUID('index', 'page');
const frontmatter = generateFrontmatter(page, 'Website');
---

<BaseLayout frontmatter={frontmatter} url={Astro.url}>
	<section class="hero">
		<h1>{__('component.hero.title')}</h1>
		<h2>{__('component.hero.subtitle')}</h2>
		<span class="hero-location">
			<span class="gg-pin"></span>
			<span>{__('component.hero.location')}</span>
			<span class="gg-time"></span>
			<Time interval={1000} format={'TIME_24_WITH_SHORT_OFFSET'} timezone={'Europe/London'} />
		</span>
	</section>

	<div class="container">
		<SliceLibrary slices={page.data.slices} />
	</div>

	<div class="container container-feed">
		<GithubActivityFeed containerClass="" />
		<GithubInsights containerClass="" headings={false} popularity={true} distribution={false} />
	</div>

	<div class="container">
		<TechStack />
	</div>

	<script define:vars={{ BASE_URL: env.BASE_URL }}>
		document.addEventListener('DOMContentLoaded', () => {
			try {
				const worker = new Worker(new URL('service-worker.js?v=2.02', BASE_URL));

				worker.postMessage({ type: 'getActivityFeed' });

				worker.onmessage = (e) => {
					if (typeof e.data === 'object' && e.data.type === 'insights' && e.data?.detail) {
						if (e.data.detail.activity) {
							document.dispatchEvent(
								new CustomEvent('x-activity-timeline', {
									detail: e.data.detail.activity,
								}),
							);
						}

						if (e.data.detail.insights) {
							document.dispatchEvent(
								new CustomEvent('x-insights', {
									detail: e.data.detail.insights,
								}),
							);
						}
					}
				};

				worker.onerror = (error) => {
					console.error('Service Worker error:', error.message);
					document.dispatchEvent(
						new CustomEvent('x-activity-timeline', {
							detail: { groups: [] },
						}),
					);
				};
			} catch (err) {
				console.error('Failed to initialise service worker: ', err);
			}
		});
	</script>
</BaseLayout>

<style is:global>
	.main {
		padding: 0;
	}

	.latest {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--gap);
		margin-top: var(--gap);
	}

	.hero {
		position: relative;
		min-height: 70svh;
		align-content: center;
		padding: var(--gap-xl) var(--gap-xl);
		width: 100%;
		overflow: hidden;

		h1 {
			font-size: 4rem;
			color: var(--primary);
			letter-spacing: -0.25rem;
			text-align: center;
			line-height: 1;
			font-weight: 500;
			margin: 0;
			margin-left: -5px;
			text-shadow: 0px 2px 4px light-dark(rgba(255, 255, 255, 0.3), rgba(0, 0, 0, 0.3));
			word-break: unset;
			min-width: 100%;
		}

		h2 {
			font-weight: 300;
			font-size: var(--font-size-h3);
			text-align: center;
			color: light-dark(var(--text-muted), var(--text));
			margin: 0.75rem 0 1.25rem 0;
			text-shadow: 0px 1px 2px light-dark(rgba(255, 255, 255, 0.3), rgba(0, 0, 0, 0.3));
			letter-spacing: -0.15rem;
			overflow: hidden;
			word-break: unset;
			min-width: 100%;
		}

		[class^='gg-']:not(:first-of-type) {
			margin-left: var(--gap-xs);
		}
	}

	.hero::before {
		content: '';
		background-color: var(--bg);
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
	}

	.hero::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		background: linear-gradient(-135deg, var(--bg), var(--accent), var(--bg));
		background-size: 350% 350%;
		animation: header-gradient 30s ease infinite;
		animation-duration: 15s;
		opacity: 0.3;
	}

	.hero-location {
		display: flex;
		width: fit-content;
		padding: 1rem;
		border-radius: var(--border-radius-lg);
		justify-content: center;
		background: oklch(from var(--surface-1) l c h / 0.5);
		flex-direction: row;
		color: light-dark(var(--text-muted), var(--text));
		gap: var(--gap-xs);
		align-items: center;
		margin: 0.5rem auto;
		font-size: small;
		text-shadow: 0px 1px 2px light-dark(rgba(255, 255, 255, 0.3), rgba(0, 0, 0, 0.3));
	}

	.container-feed {
		position: relative;
		display: grid;
		grid-template-columns: 1fr;
		flex-direction: row;
	}

	.icon-grid-block {
		margin-top: var(--gap-lg);
	}

	.icon-grid-item-title {
		font-size: var(--font-size-h4);
		font-weight: 400;
	}

	@media (--vp-md) {
		.hero {
			h1 {
				font-size: 5rem;
			}

			h2 {
				font-size: var(--font-size-h2);
			}
		}

		.latest {
			gap: var(--gap-lg);
			grid-template-columns: 1fr 1fr 1fr;
		}

		.container {
			padding: calc(var(--gap-xxl) * 2) var(--gap-xxl);
		}

		.container-feed {
			gap: var(--gap);
			grid-template-columns: 2fr 1fr;
		}
	}

	@keyframes slideinT {
		0% {
			opacity: 0.25;
			transform: scaleY(0.85) scaleX(0.85);
		}
		100% {
			opacity: 1;
			transform: scaleY(1) scaleX(1);
		}
	}
</style>
